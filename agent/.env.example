# Slack Bot Token (xoxb-...)
# Create at https://api.slack.com/apps -> OAuth & Permissions
# Required scopes: channels:history, chat:write, groups:history, im:history
SLACK_BOT_TOKEN=xoxb-your-token-here

# Notion Integration Token (ntn_...)
# Create at https://www.notion.so/my-integrations
# Share your Personal Task Tracker database with the integration
NOTION_TOKEN=ntn_your-token-here

# Notion Personal Task Tracker database ID
NOTION_DATABASE_ID=31381f88091081869611c3a55af8287e

# Slack channel or DM ID to monitor for task messages
# Find via: Slack channel details -> copy channel ID
SLACK_CHANNEL_ID=C0123456789

# How often to check for new messages (seconds)
POLL_INTERVAL=30

# Optional: only process messages starting with this prefix (e.g. "/task")
# Leave empty to process ALL messages in the channel as tasks
TASK_PREFIX=
